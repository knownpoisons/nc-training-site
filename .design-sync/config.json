{
  "projectId": "5e38ff23-246e-4272-b5bd-c6e6c7fee5c7",
  "shape": "package",
  "pkg": "nc-training-site",
  "globalName": "NotContentDS",
  "srcDir": "src/components/ds",
  "tsconfig": "tsconfig.json",
  "cssEntry": ".design-sync/shipped.css",
