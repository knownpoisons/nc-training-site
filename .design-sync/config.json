    "Cooper Hewitt",
    "Source Serif",
    "Inter",
    "Helvetica",
    "IBM Plex",
    "Georgia",
    "Menlo"
  ],
  "componentSrcMap": {
    "Page": "src/components/ds/index.tsx",
    "Topbar": "src/components/ds/index.tsx",
    "Accent": "src/components/ds/index.tsx",
    "Eyebrow": "src/components/ds/index.tsx",
    "Hero": "src/components/ds/index.tsx",
    "SectionHead": "src/components/ds/index.tsx",
    "Section": "src/components/ds/index.tsx",
    "RowList": "src/components/ds/index.tsx",
    "Row": "src/components/ds/index.tsx",
    "Button": "src/components/ds/index.tsx",
    "InlineLink": "src/components/ds/index.tsx",
    "Footer": "src/components/ds/index.tsx"
